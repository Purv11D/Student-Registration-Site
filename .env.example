# Copy this file to .env and fill in your values
# DO NOT commit .env to GitHub

# MongoDB Connection String
# Local: mongodb://localhost:27017/eventregistration
# MongoDB Atlas: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/eventregistration
MONGO_URI=mongodb://localhost:27017/eventregistration

# Server Port (Render sets this automatically)
PORT=3000
